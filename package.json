{
	"name": "@d-zero/frontend-guidelines",
	"version": "5.0.0-alpha.0",
	"description": "D-ZERO Frontend Developer's Guideline",
	"repository": "https://github.com/d-zero-dev/frontend-guidelines.git",
	"author": "D-ZERO Co., Ltd.",
	"license": "CC BY-NC-SA 4.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vitepress dev src",
		"build": "vitepress build src",
		"lint": "run-s lint:eslint lint:prettier lint:textlint lint:cspell",
		"lint:cspell": "npx cspell --no-progress --show-suggestions \"{*,src/{**,.vitepress/**}/*}/\"",
		"lint:eslint": "npx eslint --fix \"*.{js,cjs,mjs}\"",
		"lint:prettier": "npx prettier --write \"{*,src/{**,.vitepress/**}/*}.{md,json,js,cjs,mjs,jsx,ts,cts,mts,tsx}\"",
		"lint:textlint": "npx textlint --fix ./src/{**,.vitepress/**}/*.md; npx textlint ./src/{**,.vitepress/**}/*.md",
		"release:major": "npm version major",
		"release:minor": "npm version minor",
		"release:patch": "npm version patch",
		"up": "yarn upgrade-interactive --latest"
	},
	"devDependencies": {
		"@d-zero/cspell-config": "5.0.0",
		"@d-zero/eslint-config": "5.0.0",
		"@d-zero/lint-staged-config": "5.0.0",
		"@d-zero/prettier-config": "5.0.0",
		"@d-zero/textlint-config": "5.0.0",
		"@d-zero/tsconfig": "0.5.0",
		"mermaid": "11.12.3",
		"npm-run-all2": "8.0.4",
		"typescript": "5.9.3",
		"vitepress": "1.6.4",
		"vitepress-plugin-mermaid": "2.0.17"
	},
	"packageManager": "yarn@4.12.0",
	"volta": {
		"node": "24.14.0",
		"yarn": "4.12.0"
	}
}
